{
  "name": "cc-lb",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/daniel100097/cc-lb.git"
  },
  "homepage": "https://github.com/daniel100097/cc-lb#readme",
  "bugs": {
    "url": "https://github.com/daniel100097/cc-lb/issues"
  },
  "scripts": {
    "dev": "bun run build && bun --watch src/index.ts",
    "dev:server": "bun --watch src/index.ts",
    "build": "bun run build:html && bun run build:css && bun run build:client",
    "build:html": "mkdir -p public/assets && cp frontend/index.html public/index.html && if [ -d frontend/public ]; then cp -R frontend/public/. public/; fi",
    "build:css": "tailwindcss -i frontend/src/index.css -o public/assets/index.css --minify",
    "build:client": "bun build frontend/src/main.tsx --target browser --outdir public/assets --entry-naming [name].js --chunk-naming [name]-[hash].js --asset-naming [name]-[hash].[ext] --minify",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint .",
    "test": "bun test ./src/*.test.ts ./src/**/*.test.ts ./frontend/src/**/*.test.ts",
    "test:e2e": "playwright test",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "start": "bun src/index.ts",
    "healthcheck": "bun src/healthcheck.ts",
    "compare-proxy": "bun run scripts/compare-proxy.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/cli": "^4.3.2",
    "@types/bun": "latest",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "^0.31.10",
    "oxlint": "^1.72.0",
    "oxlint-tsgolint": "^0.24.0",
    "shadcn": "^4.13.0",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@anthropic-ai/claude-code": "2.1.207",
    "@hookform/resolvers": "^5.4.0",
    "@tanstack/react-query": "^5.101.2",
    "@trpc/client": "^11.18.0",
    "@trpc/react-query": "^11.18.0",
    "@trpc/server": "^11.18.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.23.0",
    "radix-ui": "^1.6.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.80.0",
    "react-router-dom": "^7.18.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "trustedDependencies": [
    "@anthropic-ai/claude-code"
  ]
}
